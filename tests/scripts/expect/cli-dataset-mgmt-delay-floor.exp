# Verifies that a MGMT_ACTIVE_SET request which changes the Network Key is
# applied through the Pending Dataset with at least the default delay
# (OPENTHREAD_CONFIG_TMF_PENDING_DATASET_DEFAULT_DELAY, 300s), regardless of
# whether the request omits the Delay Timer TLV or carries a short one.

source "tests/scripts/expect/_common.exp"

spawn_node 1
setup_leader

# Case A: key-changing MGMT_ACTIVE_SET without a Delay Timer TLV.

send "dataset mgmtsetcommand active activetimestamp 99999998 networkkey 00112233445566778899aabbccddee0a\n"
expect_line "Done"

sleep 2

send "dataset pending\n"
expect -re {Delay: (\d+)}
set delay $expect_out(1,string)
expect -re {Network Key: 00112233445566778899aabbccddee0a}
expect_line "Done"

if {$delay < 250000} {
    fail "Pending delay for key change (no Delay Timer TLV) is $delay ms, expected the 300s default delay floor"
}

# Case B: key-changing MGMT_ACTIVE_SET with a short explicit Delay Timer TLV.

send "dataset mgmtsetcommand active activetimestamp 99999999 networkkey 00112233445566778899aabbccddee0b delaytimer 5000\n"
expect_line "Done"

sleep 2

send "dataset pending\n"
expect -re {Delay: (\d+)}
set delay $expect_out(1,string)
expect -re {Network Key: 00112233445566778899aabbccddee0b}
expect_line "Done"

if {$delay < 250000} {
    fail "Pending delay for key change (explicit 5s Delay Timer TLV) is $delay ms, expected the 300s default delay floor"
}

dispose_all
